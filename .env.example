# Server
NODE_ENV=production
PORT=4000
SESSION_SECRET=replace-with-a-long-random-secret-min-32-chars

# Admin credentials
ADMIN_USERNAME=operator
ADMIN_PASSWORD=replace-with-a-strong-password

# CORS - must match your public domain exactly, no trailing slash
CLIENT_ORIGIN=https://yourdomain.com

# Database (optional - defaults to server/db/killerwhaleslabs.sqlite)
DATABASE_PATH=

# Logo storage: local | r2 | supabase
LOGO_STORAGE_PROVIDER=r2

# Cloudflare R2 (required if LOGO_STORAGE_PROVIDER=r2)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=project-logos
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
CLOUDFLARE_R2_ENDPOINT=

# Supabase (required if LOGO_STORAGE_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_LOGO_BUCKET=project-logos
SUPABASE_SERVICE_ROLE_KEY=

# Etherscan (get a free key at etherscan.io/apis)
ETHERSCAN_API_KEY=YourApiKeyToken
ETHERSCAN_CHAIN_ID=1
