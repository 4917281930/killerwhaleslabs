{
  "name": "killerwhaleslabs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite --config client/vite.config.js --host 0.0.0.0",
    "server:dev": "nodemon server/server.js",
    "server:start": "node server/server.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --config client/vite.config.js --host 0.0.0.0",
    "seed": "node server/db/seed.js",
    "migrate:logo-blobs": "node server/scripts/migrateLogoBlobs.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.5"
  }
}
